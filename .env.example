# Sentry error monitoring
# Get your DSN from: Sentry dashboard → Settings → Projects → tap-web → Client Keys (DSN)
# Required for error tracking in production
SENTRY_DSN=

# Site URL for canonical links and Open Graph tags
# Example: https://tap-shirt.com
# Optional: defaults to localhost:3000 in development
NEXT_PUBLIC_SITE_URL=

# Sentry environment (optional)
# Helps filter errors by deployment stage in Sentry dashboard
# Example: production, staging, preview
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
